{
	"version": 2,
	"builds": [
		{
			"src": "project-A/app.js",
			"use": "@vercel/node"
		},
		{
			"src": "project-C/package.json",
			"use": "@vercel/static-build",
			"config": { "distDir": "dist" }
		}
	],
	"rewrites": [
		{
			"source": "/project-A/(.*)",
			"destination": "/project-A/app.js"
		}
	]
}
