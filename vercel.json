{
	"version": 2,
	"builds": [
		{
			"src": "project-A/app.js",
			"use": "@vercel/node"
		},
		{
			"src": "project-C/package.json",
			"use": "@vercel/static-build",
			"config": { "distDir": "dist" }
		},
		{
			"src": "project-C/**/*",
			"use": "@vercel/static"
		}
	],
	"rewrites": [
		{
			"source": "/project-C/:path*",
			"destination": "/project-C/:path*"
		},
		{
			"source": "/project-D/(.*)",
			"destination": "/project-D/$1"
		},
		{
			"source": "/:path*",
			"destination": "/"
		}
	]
}
