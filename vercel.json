{
	"version": 2,
	"builds": [
		{
			"src": "project-A/app.js",
			"use": "@vercel/node"
		},
		{
			"src": "project-B/package.json",
			"use": "@vercel/static-build",
			"config": { "distDir": "dist" }
		},
		{
			"src": "project-C/package.json",
			"use": "@vercel/static-build",
			"config": { "distDir": "dist" }
		},
		{
			"src": "project-D/package.json",
			"use": "@vercel/static-build",
			"config": { "distDir": "dist" }
		},
		{
			"src": "project-E/package.json",
			"use": "@vercel/static-build",
			"config": {
				"buildCommand": "node build.js",
				"distDir": "dist"
			}
		}
	],
	"rewrites": [
		{
			"source": "/",
			"destination": "/project-A/app.js"
		},
		{
			"source": "/project-B/:path*",
			"destination": "/project-B/index.html"
		},
		{
			"source": "/project-C/:path*",
			"destination": "/project-C/:path*"
		},
		{
			"source": "/project-D/:path*",
			"destination": "/project-D/:path*"
		},
		{
			"source": "/project-D/:path*",
			"destination": "/project-D/:path*"
		},
		{
			"source": "/project-E/",
			"destination": "/project-E/index.html"
		},
		{
			"source": "/project-E/:path*",
			"destination": "/project-E/:path*"
		},
		{
			"source": "/:path*",
			"destination": "/project-A/app.js"
		}
	]
}
